{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "python -m http.server 8000",
    "beforeBuildCommand": "node scripts/tauri-copy-dist.js",
    "devPath": "http://localhost:8000",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "ระบบใบกำกับสินค้า",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "open": true,
        "save": true
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "createDir": true,
        "scope": ["$APPDATA/*", "$DESKTOP/*", "$DOWNLOAD/*", "$DOCUMENT/*"]
      },
      "path": {
        "all": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true,
        "setTitle": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Business",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.wt.invoice",
      "longDescription": "ระบบใบกำกับสินค้าสำหรับธุรกิจน้ำดื่ม",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "ระบบใบกำกับสินค้า",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": {
          "language": "th-TH"
        }
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src https://*.googleapis.com https://*.google.com https://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://ipapi.co https://ipinfo.io https://fonts.gstatic.com https://fonts.googleapis.com 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "ระบบใบกำกับสินค้า",
        "url": "http://localhost:8000/index.html",
        "width": 1400,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "fileDropEnabled": false
      }
    ]
  }
}
