{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "python -m http.server 8000",
    "beforeBuildCommand": "node scripts/tauri-copy-dist.js",
    "devPath": "http://localhost:8000",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "ระบบใบกำกับสินค้า",
    "version": "1.0.72"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "open": true,
        "save": true,
        "confirm": true,
        "message": true,
        "ask": true
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "createDir": true,
        "scope": ["$APPDATA/*", "$DESKTOP/*", "$DOWNLOAD/*", "$DOCUMENT/*"]
      },
      "path": {
        "all": true
      },
      "os": {
        "all": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true,
        "setTitle": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Business",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.wt.invoice",
      "longDescription": "ระบบใบกำกับสินค้าสำหรับธุรกิจน้ำดื่ม",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "ระบบใบกำกับสินค้า",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": {
          "language": "th-TH"
        }
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/pure-water-ska/invoice-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEQkJDNzBCMkM1RTZBMEIKUldRTGFsNHNDOGU3N2NLNkFsVjIzdGtMbHNodVkrbVk3b1RTditCNWVCUnNpeS9sNnhPdFdUa1UK"
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "ระบบใบกำกับสินค้า",
        "url": "index.html",
        "width": 1400,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "fileDropEnabled": false
      }
    ]
  }
}
